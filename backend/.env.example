# MongoDB connection string (use strong credentials)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=sls_fleet_db

# JWT secret — MUST be a strong random string (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# Admin default password (used only when seeding first admin user)
ADMIN_DEFAULT_PASSWORD=CHANGE_ME

# CORS origins (comma-separated, no wildcard in production)
CORS_ORIGINS=https://slts.group,http://localhost:3000

# Optional: Gemini AI API key for chatbot
GEMINI_API_KEY=

# Optional: Cloudinary for image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
